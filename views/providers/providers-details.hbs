<!-- Provider Details Section -->
<section class="page-section" id="providers-details">
    <div class="container px-4 px-lg-5">
        <h2 class="text-center mt-0">{{ company.company_name}}</h2>
        <hr class="divider" />

        <div class="row mb-4">
            <div class="col-sm-6 mb-3 mb-sm-0">
                <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Description</h5>
                    <p class="card-text">{{company.description}}</p>
                    
                </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Tag Line</h5>
                    <p class="card-text">{{ company.tagline }}</p>
                </div>
                </div>
            </div>
        </div>

        <div class="table-reponsive">
            <table class="table table-hover table-bordered">
                <thead class="thead-light">
                    <tr>
                        <th scope="col">Id</th>
                        <th scope="col">Adress</th>
                        <th scope="col">Address2</th>
                        <th scope="col">City</th>
                        <th scope="col">State</th>
                        <th scope="col">Zip Code</th>
                        <th scope="col">Phone</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td scope="row">{{ id }}</td>
                        <td scope="row">{{ company.address }}</td>
                        <td scope="row">{{ company.address2 }}</td>
                        <td scope="row">{{ company.city }}</td>
                        <td scope="row">{{ company.state }}</td>
                        <td scope="row">{{ company.postal_code }}</td>
                        <td scope="row">{{ company.phone }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <td scope="row my-5">
            <div class="col-sm-12 text-center">
                <a href="/providers/edit/{{id}}" class="btn btn-secondary btn-sm"> Edit Provider</a>
            </div>
        </td>
    </div>
</section>