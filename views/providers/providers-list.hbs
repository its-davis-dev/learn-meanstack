<!-- Provider List Section -->
<section class="page-section" id="provider-list">
    <div class="container px-4 px-lg-5">
        <h2 class="text-center mt-0">At Your Service</h2>
        <hr class="divider" />

        <div class="table-reponsive">
            <table class="table table-hover table-bordered">
                <thead class="thead-light">
                    <tr>
                        <th scope="col">Id</th>
                        <th scope="col">First</th>
                        <th scope="col">Last</th>
                        <th scope="col">Position</th>
                        <th scope="col">Company</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    {{#each providers}}
                    <tr>
                        <td scope="row">{{ id }}</td>
                        <td scope="row">{{ firstname }}</td>
                        <td scope="row">{{ lastname }}</td>
                        <td scope="row">{{ position }}</td>
                        <td scope="row">{{ company.company_name }}</td>
                        <td scope="row">
                            <a href="/providers/details/{{id}}" class="btn btn-info btn-sm">More info...</a>
                        </td>
                        <td scope="row">
                            <a href="providers/edit/{{id}}" class="btn btn-secondary btn-sm">
                            Edit
                            </a>
                        </td>
                        <td scope="row">
                            <a href="providers/edit/{{id}}" class="btn btn-danger btn-sm">
                            Delete
                            </a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

    </div>
</section>